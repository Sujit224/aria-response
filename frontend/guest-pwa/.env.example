# ARIA Guest PWA — Environment Variables
# Copy to .env and fill in values from your Firebase console

# Backend API (defaults work for local dev via Vite proxy)
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000

# Your venue/hotel ID (from ingest_hotel.py output)
VITE_VENUE_ID=your_hotel_id_here

# Firebase Web App Config
# Get from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# FCM VAPID key for push notifications
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=
