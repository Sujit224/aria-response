# ─────────────────────────────────────────────────────────
# ARIA — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env or serviceAccount.json to git
# ─────────────────────────────────────────────────────────

# ── Groq (LLM) ────────────────────────────────────────────
# Get free key at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Firebase ──────────────────────────────────────────────
# Path to your Firebase service account JSON key
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=secrets/serviceAccount.json

# ── Venue ─────────────────────────────────────────────────
# Set after running ingest_hotel.py — it will print this value
VENUE_ID=your_hotel_document_id_here

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
